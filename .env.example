# Supabase project URL
# Example: https://xxxxxxxxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# Supabase client-side publishable key.
# Safe to expose in browser, but still keep the value in env config.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Supabase server-side secret key.
# Never expose this in frontend code.
SUPABASE_SECRET_KEY=

# Optional shared secret for manually calling cron endpoints.
# Use a long random string. Vercel Cron itself is also allowed by user-agent.
CRON_SECRET=

# Optional when the frontend is deployed separately from the backend.
NEXT_PUBLIC_API_BASE_URL=

# Optional backend scheduler config.
ENABLE_WEEKLY_SCHEDULER=false
WEEKLY_SCHEDULER_CRON=0 0 * * *
WEEKLY_SCHEDULER_TIMEZONE=Asia/Seoul
LOTTO_SCHEDULER_CRON=0 0 * * *
PENSION720_SCHEDULER_CRON=10 0 * * *
